# Copy this file to .env.local — Next.js only loads .env.local (not .env.example)
BOOKING_BROOM_URL=https://bookings.kedrik.com
BOOKING_BROOM_API_KEY=your-production-secret-here
NEXT_PUBLIC_SITE_URL=https://cleaningwinterhaven.com
# Phone accepts formatted or raw digits, e.g. (863) 358-7388 or 8633587388
NEXT_PUBLIC_PHONE=(863) 000-0000
NEXT_PUBLIC_EMAIL=hello@cleaningwinterhaven.com
